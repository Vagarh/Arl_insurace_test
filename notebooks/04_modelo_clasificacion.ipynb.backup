   "cell_type": "markdown",
   "id": "section5",
   "metadata": {},
   "source": [
    "---\n",
    "## 5. Clasificación en batch (carga semanal)\n",
    "\n",
    "Procesar múltiples quejas a la vez"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "batch_function",
   "metadata": {},
   "outputs": [],
   "source": [
    "def clasificar_batch(df_nuevas):\n",
    "    \"\"\"\n",
    "    Clasifica un DataFrame de quejas nuevas\n",
    "    \n",
    "    Args:\n",
    "        df_nuevas: DataFrame con columnas ['descripcion', 'canal', 'cliente', ...]\n",
    "    \n",
    "    Returns:\n",
    "        DataFrame con predicciones agregadas\n",
    "    \"\"\"\n",
    "    resultados = []\n",
    "    \n",
    "    for idx, row in df_nuevas.iterrows():\n",
    "        # Clasificar\n",
    "        resultado = clasificar_queja(\n",
    "            descripcion=row['descripcion'],\n",
    "            canal=row['canal'],\n",
    "            mes=row.get('mes', None),\n",
    "            cliente_recurrente=row.get('cliente_recurrente', False),\n",
    "            n_quejas_cliente=row.get('n_quejas_cliente', 1)\n",
    "        )\n",
    "        \n",
    "        # Combinar con datos originales\n",
    "        resultado_completo = {\n",
    "            'id_queja': idx,\n",
    "            'cliente': row.get('cliente', 'N/A'),\n",
    "            'canal': row['canal'],\n",
    "            'descripcion_original': row['descripcion'][:100] + '...' if len(row['descripcion']) > 100 else row['descripcion'],\n",
    "            **resultado\n",
    "        }\n",
    "        \n",
    "        resultados.append(resultado_completo)\n",
    "    \n",
    "    return pd.DataFrame(resultados)\n",
    "\n",
    "print(\"✓ Función de clasificación batch definida\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "simulate_batch",
   "metadata": {},
   "outputs": [],
   "source": [
    "# Simular carga semanal con muestra de datos históricos\n",
    "print(\"Simulando carga semanal con 50 quejas aleatorias...\")\n",
    "\n",
    "# Tomar muestra aleatoria\n",
    "df_simulacion = df_hist.sample(n=50, random_state=42)[['descripcion', 'canal', 'cliente']].copy()\n",
    "df_simulacion.reset_index(drop=True, inplace=True)\n",
    "\n",
    "# Clasificar en batch\n",
    "%%time\n",
    "df_resultados = clasificar_batch(df_simulacion)\n",
    "\n",
    "print(f\"\\n✓ Procesadas {len(df_resultados)} quejas\")\n",
    "print(f\"\\nDistribución de predicciones:\")\n",
    "print(df_resultados['prediccion'].value_counts())\n",
    "print(f\"\\nDistribución de nivel de riesgo:\")\n",
    "print(df_resultados['nivel_riesgo'].value_counts())\n",
    "\n",
    "df_resultados.head(10)"
   ]
  },
