    "# Preparar datos para dashboard\n",
    "OUTPUT_PATH = Path(BASE_DIR) / 'dashboard'\n",
    "OUTPUT_PATH.mkdir(exist_ok=True)\n",
    "\n",
    "# 1. Resultados de clasificación\n",
    "df_resultados['fecha_clasificacion'] = datetime.now().strftime('%Y-%m-%d %H:%M:%S')\n",
