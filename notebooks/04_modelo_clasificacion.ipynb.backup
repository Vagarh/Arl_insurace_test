   "source": [
    "---\n",
    "## 6. Sistema de alertas y priorización"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "alertas",
   "metadata": {},
   "outputs": [],
   "source": [
    "# Sistema de priorización\n",
    "def generar_alertas(df_resultados, umbral_critico=0.7, umbral_alto=0.5):\n",
    "    \"\"\"\n",
    "    Genera alertas y prioriza quejas según riesgo\n",
    "    \"\"\"\n",
    "    # Casos críticos\n",
    "    criticos = df_resultados[df_resultados['probabilidad_grave'] >= umbral_critico]\n",
    "    \n",
    "    # Casos de riesgo alto\n",
    "    alto_riesgo = df_resultados[\n",
    "        (df_resultados['probabilidad_grave'] >= umbral_alto) & \n",
    "        (df_resultados['probabilidad_grave'] < umbral_critico)\n",
    "    ]\n",
    "    \n",
    "    print(\"=\"*100)\n",
    "    print(\"🚨 SISTEMA DE ALERTAS\")\n",
    "    print(\"=\"*100)\n",
    "    \n",
    "    print(f\"\\n🔴 CASOS CRÍTICOS (probabilidad ≥ {umbral_critico:.0%}): {len(criticos)}\")\n",
    "    if len(criticos) > 0:\n",
    "        print(\"\\nTOP 5 CASOS CRÍTICOS:\")\n",
    "        top_criticos = criticos.nlargest(5, 'probabilidad_grave')\n",
    "        for i, (idx, caso) in enumerate(top_criticos.iterrows(), 1):\n",
    "            print(f\"\\n  {i}. Cliente: {caso['cliente']} | Canal: {caso['canal']}\")\n",
    "            print(f\"     Probabilidad: {caso['probabilidad_grave']:.1%} | Términos: {', '.join(caso['terminos_detectados'][:3])}\")\n",
    "            print(f\"     Descripción: {caso['descripcion_original'][:80]}...\")\n",
    "    \n",
    "    print(f\"\\n🟡 CASOS DE RIESGO ALTO (probabilidad {umbral_alto:.0%}-{umbral_critico:.0%}): {len(alto_riesgo)}\")\n",
    "    \n",
    "    print(f\"\\n📊 RESUMEN GENERAL:\")\n",
    "    print(f\"  - Total quejas procesadas: {len(df_resultados)}\")\n",
    "    print(f\"  - Críticos: {len(criticos)} ({len(criticos)/len(df_resultados)*100:.1f}%)\")\n",
    "    print(f\"  - Alto riesgo: {len(alto_riesgo)} ({len(alto_riesgo)/len(df_resultados)*100:.1f}%)\")\n",
    "    print(f\"  - Riesgo medio/bajo: {len(df_resultados) - len(criticos) - len(alto_riesgo)}\")\n",
    "    \n",
    "    return criticos, alto_riesgo\n",
    "\n",
    "criticos, alto_riesgo = generar_alertas(df_resultados)"
   ]
  },
