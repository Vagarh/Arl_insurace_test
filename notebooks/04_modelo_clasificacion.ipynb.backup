    "fig, axes = plt.subplots(1, 2, figsize=(14, 5))\n",
    "\n",
    "# Histograma de probabilidades\n",
    "axes[0].hist(df_resultados['probabilidad_grave'], bins=20, color='steelblue', edgecolor='white')\n",
    "axes[0].axvline(0.5, color='orange', linestyle='--', linewidth=2, label='Alto riesgo (0.5)')\n",
    "axes[0].axvline(0.7, color='red', linestyle='--', linewidth=2, label='Crítico (0.7)')\n",
    "axes[0].set_xlabel('Probabilidad de insatisfacción grave')\n",
