    "print(f\"  - {OUTPUT_PATH / 'resumen_alertas.json'}\")\n",
    "print(f\"  - {OUTPUT_PATH / 'casos_criticos.csv'}\")\n",
    "\n",
    "print(\"\\n📊 Resumen de alertas:\")\n",
    "print(json.dumps(resumen_alertas, indent=2, ensure_ascii=False))"
