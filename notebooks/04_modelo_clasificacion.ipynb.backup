    "        'terminos_detectados', 'descripcion_original'\n",
    "    ]].copy()\n",
    "    criticos_export.to_csv(OUTPUT_PATH / 'casos_criticos.csv', index=False)\n",
    "\n",
    "print(\"✓ Datos exportados para dashboard:\")\n",
