    "print(f\"Features esperadas: {len(metadatos['features'])}\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "feature_extraction",
   "metadata": {},
   "outputs": [],
   "source": [
    "# === 3.2 Función de extracción de features (para nuevas quejas) ===\n",
    "def extraer_features_texto(texto_limpio, len_original, metadatos):\n",
    "    \\\"\\\"\\\"\n",
    "    Extrae todas las features necesarias de un texto\n",
    "    \\\"\\\"\\\"\n",
    "    features = {}\n",
    "    \n",
    "    # Features de términos clave\n",
    "    for nombre, terminos in metadatos['terminos_clave'].items():\n",
    "        pattern = '|'.join(terminos)\n",
    "        features[f'tiene_{nombre}'] = int(bool(re.search(pattern, texto_limpio, re.IGNORECASE)))\n",
    "    \n",
    "    # Features de texto\n",
    "    features['n_tokens'] = len(texto_limpio.split()) if texto_limpio else 0\n",
    "    features['texto_largo'] = int(len_original > metadatos['umbral_texto_largo'])\n",
    "    features['texto_corto'] = int(len_original < metadatos['umbral_texto_corto'])\n",
    "    features['n_terminos_clave'] = sum([features[f'tiene_{k}'] for k in metadatos['terminos_clave'].keys()])\n",
    "    \n",
    "    # Combinaciones\n",
    "    features['pago_y_tiempo'] = int(features.get('tiene_pago', 0) and features.get('tiene_tiempo', 0))\n",
    "    features['tramite_y_respuesta'] = int(features.get('tiene_tramite', 0) and features.get('tiene_respuesta', 0))\n",
    "    \n",
    "    return features\n",
    "\n",
    "print(\"✓ Función de extracción de features definida\")"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "section3",
   "metadata": {},
   "source": [
    "---\n",
    "## 3. Pipeline de clasificación de nuevas quejas\n",
    "\n",
    "Sistema completo para clasificar quejas que lleguen en el futuro\n",
    "\n",
    "**NOTA:** Las funciones de limpieza de texto (`limpiar_texto`) ya están definidas arriba en la sección de preprocesamiento."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "load_model",
   "metadata": {},
   "outputs": [],
   "source": [
    "# Cargar modelo y metadatos\n",
    "MODEL_PATH = Path(BASE_DIR) / 'models' / 'clasificador_quejas.pkl'\n",
    "METADATA_PATH = Path(BASE_DIR) / 'models' / 'metadatos_modelo.pkl'\n",
    "\n",
    "with open(MODEL_PATH, 'rb') as f:\n",
    "    modelo = pickle.load(f)\n",
    "\n",
    "with open(METADATA_PATH, 'rb') as f:\n",
    "    metadatos = pickle.load(f)\n",
    "\n",
    "print(\"✓ Modelo cargado\")\n",
    "print(f\"Fecha de entrenamiento: {metadatos['fecha_entrenamiento']}\")\n",
    "print(f\"Muestras de entrenamiento: {metadatos['n_muestras']:,}\")\n",
    "print(f\"Features esperadas: {len(metadatos['features'])}\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "clasificar_function",
   "metadata": {},
   "outputs": [],
   "source": [
    "# === 3.3 Función de clasificación ===\n",
    "def clasificar_queja(descripcion, canal, mes=None):\n",
    "    \\\"\\\"\\\"\n",
    "    Clasifica una queja nueva y retorna predicción + explicación\n",
    "    \n",
    "    Args:\n",
    "        descripcion (str): Texto de la queja\n",
    "        canal (str): Canal de comunicación\n",
    "        mes (int): Mes del año (1-12), opcional\n",
    "    \n",
    "    Returns:\n",
    "        dict con predicción, probabilidad y features detectadas\n",
    "    \\\"\\\"\\\"\n",
    "    # 1. Preprocesar texto\n",
    "    len_original = len(descripcion)\n",
    "    texto_limpio = limpiar_texto(descripcion)\n",
    "    \n",
    "    # 2. Extraer features de texto\n",
    "    features = extraer_features_texto(texto_limpio, len_original, metadatos)\n",
    "    \n",
    "    # 3. Features de canal (one-hot)\n",
    "    for canal_modelo in metadatos['canales_entrenamiento']:\n",
    "        canal_nombre = canal_modelo.replace('canal_', '')\n",
    "        features[canal_modelo] = int(canal == canal_nombre)\n",
    "    \n",
    "    # 4. Mes\n",
    "    features['mes'] = mes if mes else datetime.now().month\n",
    "    \n",
    "    # 5. Construir vector de features en el orden correcto\n",
    "    X_new = pd.DataFrame([features])[metadatos['features']]\n",
    "    \n",
    "    # 6. Predecir\n",
    "    pred = modelo.predict(X_new)[0]\n",
    "    proba = modelo.predict_proba(X_new)[0]\n",
    "    \n",
    "    # 7. Identificar features activadas\n",
    "    terminos_detectados = [k.replace('tiene_', '') for k, v in features.items() \n",
    "                          if k.startswith('tiene_') and v == 1]\n",
    "    \n",
    "    # 8. Nivel de riesgo\n",
    "    prob_grave = proba[1]\n",
    "    if prob_grave >= 0.7:\n",
    "        nivel_riesgo = 'CRÍTICO'\n",
    "    elif prob_grave >= 0.5:\n",
    "        nivel_riesgo = 'ALTO'\n",
    "    elif prob_grave >= 0.3:\n",
    "        nivel_riesgo = 'MEDIO'\n",
    "    else:\n",
    "        nivel_riesgo = 'BAJO'\n",
    "    \n",
    "    return {\n",
    "        'prediccion': 'GRAVE' if pred == 1 else 'NO GRAVE',\n",
    "        'probabilidad_grave': prob_grave,\n",
    "        'probabilidad_no_grave': proba[0],\n",
    "        'nivel_riesgo': nivel_riesgo,\n",
    "        'terminos_detectados': terminos_detectados,\n",
    "        'canal': canal,\n",
    "        'n_tokens': features['n_tokens'],\n",
    "        'es_texto_largo': bool(features['texto_largo'])\n",
    "    }\n",
    "\n",
    "print(\"✓ Función de clasificación definida\")"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "section4",
   "metadata": {},
   "source": [
