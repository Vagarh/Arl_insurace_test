   "source": [
    "# === 1.1 Cargar Excel original ===\n",
    "DATA_FILE = \"/content/drive/MyDrive/sura/BD_Quejas_Analitica.xlsx\"\n",
    "print(f\"Cargando datos desde: {DATA_FILE}\")\n",
    "\n",
    "df = pd.read_excel(DATA_FILE, sheet_name='Incapacidad Temporal')\n",
    "df.columns = ['mes_apertura', 'descripcion', 'tipo', 'cliente', 'canal']\n",
    "\n",
    "print(f\"✓ Datos cargados: {len(df):,} registros\")\n",
    "print(f\"Columnas: {df.columns.tolist()}\")\n",
    "print(f\"\\nPrimeras filas:\")\n",
    "df.head(3)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 31,
   "id": "prepare_training",
   "metadata": {},
   "outputs": [
    {
     "ename": "SyntaxError",
     "evalue": "unexpected character after line continuation character (57870462.py, line 27)",
     "output_type": "error",
     "traceback": [
      "\u001b[0;36m  File \u001b[0;32m\"/tmp/ipykernel_13484/57870462.py\"\u001b[0;36m, line \u001b[0;32m27\u001b[0m\n\u001b[0;31m    \\\"\\\"\\\"Limpieza y lematización de texto\\\"\\\"\\\"\u001b[0m\n\u001b[0m     ^\u001b[0m\n\u001b[0;31mSyntaxError\u001b[0m\u001b[0;31m:\u001b[0m unexpected character after line continuation character\n"
     ]
    }
   ],
   "source": [
    "# === 1.2 Preprocesamiento NLP completo ===\n",
    "print(\"\\n\" + \"=\"*80)\n",
    "print(\"PREPROCESAMIENTO DE TEXTO\")\n",
    "print(\"=\"*80)\n",
    "\n",
    "# Eliminar nulos\n",
    "df = df[df['descripcion'].notna()].copy()\n",
    "print(f\"\\n✓ Registros con descripción: {len(df):,}\")\n",
    "\n",
    "# Normalizar cliente\n",
    "df['cliente_norm'] = (df['cliente']\n",
    "    .str.upper()\n",
    "    .str.strip()\n",
    "    .str.replace(r'\\s+', ' ', regex=True)\n",
    "    .str.replace(r'[.,;]', '', regex=True)\n",
    ")\n",
    "\n",
    "# Stopwords del dominio\n",
    "STOPWORDS_ADICIONALES = {\n",
    "    'usuario', 'usuaria', 'cliente', 'sura', 'arl', 'queja', 'solicitar',\n",
    "    'comunicar', 'informar', 'solicitud', 'solicita', 'desear', 'desea',\n",
    "    'buenas', 'buen', 'día', 'dias', 'cordial', 'saludo', 'gracias',\n",
    "    'favor', 'porfavor', 'por', 'atención', 'atencion'\n",
    "}\n",
    "\n",
    "def limpiar_texto(texto, min_len=3):\n",
    "    \\\"\\\"\\\"Limpieza y lematización de texto\\\"\\\"\\\"\n",
    "    if not isinstance(texto, str):\n",
    "        return ''\n",
    "    \n",
    "    texto = texto.lower()\n",
    "    texto = re.sub(r'http\\\\S+|www\\\\S+', '', texto)\n",
    "    texto = re.sub(r'\\\\S+@\\\\S+', '', texto)\n",
    "    texto = re.sub(r'[^a-záéíóúñü\\\\s]', ' ', texto)\n",
    "    texto = re.sub(r'\\\\s+', ' ', texto).strip()\n",
    "    \n",
    "    doc = nlp(texto)\n",
    "    \n",
    "    tokens = [\n",
    "        token.lemma_ for token in doc\n",
    "        if not token.is_stop\n",
    "        and not token.is_punct\n",
    "        and not token.is_space\n",
    "        and len(token.text) >= min_len\n",
    "        and token.lemma_ not in STOPWORDS_ADICIONALES\n",
    "        and token.pos_ in ['NOUN', 'VERB', 'ADJ', 'PROPN']\n",
    "    ]\n",
    "    \n",
    "    return ' '.join(tokens)\n",
    "\n",
    "# Procesar textos\n",
    "print(\"\\nProcesando textos (puede tomar 1-2 minutos)...\")\n",
    "%%time\n",
    "df['texto_limpio'] = df['descripcion'].apply(limpiar_texto)\n",
    "df['n_tokens'] = df['texto_limpio'].str.split().str.len()\n",
    "df = df[df['n_tokens'] > 0].copy()\n",
    "\n",
    "print(f\"✓ Textos procesados: {len(df):,}\")\n",
    "print(f\"Promedio de tokens: {df['n_tokens'].mean():.1f}\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "fmf1grgke7s",
   "metadata": {},
   "outputs": [],
   "source": [
    "# === 1.3 Extracción de features ===\n",
    "print(\"\\n\" + \"=\"*80)\n",
    "print(\"EXTRACCIÓN DE FEATURES\")\n",
    "print(\"=\"*80)\n",
    "\n",
    "# Términos clave\n",
    "TERMINOS_CLAVE = {\n",
    "    'pago': ['pago', 'pagos', 'pagar'],\n",
    "    'incapacidad': ['incapacidad', 'incapacidades'],\n",
    "    'radicacion': ['radicacion', 'radicar', 'radicado', 'radicada'],\n",
    "    'transcurso': ['transcurso', 'transcurrido', 'transcurrir'],\n",
    "    'respuesta': ['respuesta', 'responder'],\n",
    "    'tramite': ['tramite', 'tramitar', 'tramitacion'],\n",
    "    'estado': ['estado', 'estados'],\n",
    "    'tiempo': ['tiempo', 'tiempos', 'demora', 'demorar'],\n",
    "    'certificado': ['certificado', 'certificacion'],\n",
    "    'subsanacion': ['subsanacion', 'subsanar'],\n",
    "    'tutela': ['tutela'],\n",
    "    'derecho_peticion': ['derecho', 'peticion']\n",
    "}\n",
    "\n",
    "# Detectar términos clave\n",
    "for nombre, terminos in TERMINOS_CLAVE.items():\n",
    "    pattern = '|'.join(terminos)\n",
    "    df[f'tiene_{nombre}'] = df['texto_limpio'].str.contains(pattern, case=False, regex=True).astype(int)\n",
    "\n",
    "feature_tiene = [f'tiene_{k}' for k in TERMINOS_CLAVE.keys()]\n",
    "print(f\"\\n✓ Features de términos clave: {len(feature_tiene)}\")\n",
    "\n",
    "# Features de canal\n",
    "df_canal = pd.get_dummies(df['canal'], prefix='canal')\n",
    "df = pd.concat([df, df_canal], axis=1)\n",
    "print(f\"✓ Features de canal: {len(df_canal.columns)}\")\n",
    "\n",
    "# Features adicionales\n",
    "df['len_descripcion'] = df['descripcion'].str.len()\n",
    "df['mes'] = df['mes_apertura'] % 100\n",
    "df['texto_largo'] = (df['len_descripcion'] > df['len_descripcion'].quantile(0.75)).astype(int)\n",
    "df['texto_corto'] = (df['len_descripcion'] < df['len_descripcion'].quantile(0.25)).astype(int)\n",
    "df['n_terminos_clave'] = df[feature_tiene].sum(axis=1)\n",
    "df['pago_y_tiempo'] = (df['tiene_pago'] & df['tiene_tiempo']).astype(int)\n",
    "df['tramite_y_respuesta'] = (df['tiene_tramite'] & df['tiene_respuesta']).astype(int)\n",
    "\n",
    "print(f\"✓ Features adicionales: 7\")\n",
    "\n",
    "# Variable objetivo\n",
    "freq_cliente = df.groupby('cliente_norm').size().reset_index(name='n_quejas_cliente')\n",
    "df = df.merge(freq_cliente, on='cliente_norm', how='left')\n",
    "df['escalado_entes'] = df['canal'] == 'ENTES DE CONTROL'\n",
    "df['y_insatisfaccion'] = (\n",
    "    (df['escalado_entes']) | \n",
    "    (df['n_quejas_cliente'] >= 3)\n",
    ").astype(int)\n",
    "\n",
    "print(f\"\\n✓ Variable objetivo creada\")\n",
    "print(f\"  Tasa de insatisfacción grave: {df['y_insatisfaccion'].mean()*100:.1f}%\")\n",
    "\n",
    "# Features del modelo (sin tópicos LDA - simplificación)\n",
    "features_modelo = (\n",
    "    feature_tiene +\n",
    "    df_canal.columns.tolist() +\n",
    "    ['n_tokens', 'texto_largo', 'texto_corto', 'n_terminos_clave',\n",
    "     'pago_y_tiempo', 'tramite_y_respuesta', 'mes']\n",
    ")\n",
    "\n",
    "print(f\"\\n✓ Total de features: {len(features_modelo)}\")\n",
    "print(f\"  {features_modelo}\")"
   ]
  },
