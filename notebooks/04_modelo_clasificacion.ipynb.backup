    "---\n",
    "## 8. Función de uso en producción\n",
    "\n",
    "Script simplificado para uso semanal"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "production_script",
   "metadata": {},
   "outputs": [],
   "source": [
    "def procesar_carga_semanal(archivo_nuevas_quejas, output_dir=None):\n",
    "    \"\"\"\n",
    "    Pipeline completo para procesar carga semanal\n",
    "    \n",
    "    Args:\n",
    "        archivo_nuevas_quejas: Path al CSV con columnas ['descripcion', 'canal', 'cliente']\n",
    "        output_dir: Directorio de salida (default: BASE_DIR/dashboard)\n",
    "    \n",
    "    Returns:\n",
    "        DataFrame con resultados\n",
    "    \"\"\"\n",
    "    print(\"=\"*100)\n",
    "    print(f\"PROCESAMIENTO AUTOMÁTICO DE QUEJAS - {datetime.now().strftime('%Y-%m-%d %H:%M:%S')}\")\n",
    "    print(\"=\"*100)\n",
    "    \n",
    "    # 1. Cargar datos\n",
    "    print(\"\\n[1/4] Cargando datos...\")\n",
    "    df_nuevas = pd.read_csv(archivo_nuevas_quejas)\n",
    "    print(f\"  ✓ {len(df_nuevas):,} quejas cargadas\")\n",
    "    \n",
    "    # 2. Clasificar\n",
    "    print(\"\\n[2/4] Clasificando quejas...\")\n",
    "    df_resultados = clasificar_batch(df_nuevas)\n",
    "    print(f\"  ✓ Clasificación completada\")\n",
    "    \n",
    "    # 3. Generar alertas\n",
    "    print(\"\\n[3/4] Generando alertas...\")\n",
    "    criticos, alto_riesgo = generar_alertas(df_resultados)\n",
    "    \n",
    "    # 4. Exportar\n",
    "    print(\"\\n[4/4] Exportando resultados...\")\n",
    "    if output_dir is None:\n",
    "        output_dir = Path(BASE_DIR) / 'dashboard'\n",
    "    output_dir = Path(output_dir)\n",
    "    output_dir.mkdir(exist_ok=True)\n",
    "    \n",
    "    # Exportar\n",
    "    df_resultados['fecha_clasificacion'] = datetime.now().strftime('%Y-%m-%d %H:%M:%S')\n",
    "    df_resultados.to_csv(output_dir / f\"clasificacion_{datetime.now().strftime('%Y%m%d')}.csv\", index=False)\n",
    "    \n",
    "    if len(criticos) > 0:\n",
    "        criticos.to_csv(output_dir / f\"criticos_{datetime.now().strftime('%Y%m%d')}.csv\", index=False)\n",
    "    \n",
    "    print(f\"  ✓ Resultados guardados en {output_dir}\")\n",
    "    \n",
    "    print(\"\\n\" + \"=\"*100)\n",
    "    print(\"✅ PROCESO COMPLETADO\")\n",
    "    print(\"=\"*100)\n",
    "    \n",
    "    return df_resultados\n",
    "\n",
    "print(\"✓ Función de producción definida\")"
   ]
  },
