    "axes[0].legend()\n",
    "\n",
    "# Distribución por nivel de riesgo\n",
    "nivel_counts = df_resultados['nivel_riesgo'].value_counts()\n",
    "colores = {'CRÍTICO': 'red', 'ALTO': 'orange', 'MEDIO': 'yellow', 'BAJO': 'green'}\n",
    "colors_plot = [colores.get(nivel, 'gray') for nivel in nivel_counts.index]\n",
    "\n",
    "axes[1].bar(nivel_counts.index, nivel_counts.values, color=colors_plot, edgecolor='white')\n",
    "axes[1].set_ylabel('Número de quejas')\n",
    "axes[1].set_title('Quejas por nivel de riesgo', fontweight='bold')\n",
    "\n",
    "for i, (nivel, count) in enumerate(nivel_counts.items()):\n",
    "    axes[1].text(i, count + 0.5, str(count), ha='center', fontweight='bold')\n",
    "\n",
    "plt.tight_layout()\n",
    "plt.show()"
   ]
