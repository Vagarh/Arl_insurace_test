    "    'terminos_mas_frecuentes': df_resultados['terminos_detectados'].explode().value_counts().head(10).to_dict()\n",
    "}\n",
    "\n",
    "import json\n",
    "with open(OUTPUT_PATH / 'resumen_alertas.json', 'w') as f:\n",
    "    json.dump(resumen_alertas, f, indent=2, ensure_ascii=False)\n",
    "\n",
